{
  "name": "temporal-funding-requests",
  "version": "1.0.0",
  "description": "Funding request processing workflow with Temporal",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start:worker": "tsx src/infrastructure/temporal/worker.ts",
    "start:api": "tsx src/infrastructure/http/server.ts",
    "start": "concurrently \"pnpm start:worker\" \"pnpm start:api\""
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "concurrently": "^8.2.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.1"
  }
}
