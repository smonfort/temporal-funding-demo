{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); if [[ \"$FILE\" == *.ts ]]; then ./node_modules/.bin/tsc --noEmit; fi",
            "statusMessage": "Checking TypeScript..."
          },
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); if [[ \"$FILE\" == *.ts ]]; then ./node_modules/.bin/prettier --write \"$FILE\" && ./node_modules/.bin/eslint --fix \"$FILE\"; fi",
            "statusMessage": "Formatting & linting..."
          }
        ]
      }
    ]
  }
}
